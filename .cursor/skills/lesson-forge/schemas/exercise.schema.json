{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dotlearn.dev/schemas/exercise.schema.json",
  "title": "ExerciseFile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exercises"
  ],
  "properties": {
    "exercises": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/exercise"
      }
    }
  },
  "$defs": {
    "exercise": {
      "type": "object",
      "required": [
        "id",
        "concept",
        "type",
        "difficulty",
        "prompt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "concept": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$"
        },
        "type": {
          "type": "string",
          "enum": [
            "theory-quiz",
            "sql-query",
            "python-function",
            "javascript-function",
            "fill-in-blanks",
            "predict-output",
            "git-challenge"
          ]
        },
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "prompt": {
          "type": "string",
          "minLength": 5
        },
        "hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fixture": {
          "type": "string"
        },
        "starter": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "snippet": {
          "type": "string"
        },
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "text"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "correct": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "explanation": {
          "type": "string"
        },
        "cases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "call"
            ],
            "properties": {
              "call": {
                "type": "string"
              },
              "expect": {},
              "expect_approx": {
                "type": "number"
              }
            }
          }
        },
        "blanks": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "accept_regex": {
                "type": "string"
              }
            }
          }
        },
        "expected": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "result-set",
                "scalar",
                "stdout"
              ]
            },
            "ordered": {
              "type": "boolean"
            },
            "rows": {
              "type": "array"
            },
            "value": {}
          }
        },
        "solution": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "setup": {
          "$ref": "#/$defs/gitSetup"
        },
        "goal": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/gitGoal"
          }
        },
        "variants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/variant"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "theory-quiz"
              }
            }
          },
          "then": {
            "required": [
              "choices",
              "correct"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "sql-query"
              }
            }
          },
          "then": {
            "required": [
              "fixture",
              "expected",
              "solution"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "python-function",
                  "javascript-function"
                ]
              }
            }
          },
          "then": {
            "required": [
              "starter",
              "cases",
              "solution"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "fill-in-blanks"
              }
            }
          },
          "then": {
            "required": [
              "template",
              "blanks"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "predict-output"
              }
            }
          },
          "then": {
            "required": [
              "snippet",
              "expected"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "git-challenge"
              }
            }
          },
          "then": {
            "required": [
              "goal",
              "solution"
            ]
          }
        }
      ]
    },
    "variant": {
      "type": "object",
      "description": "A full alternative variation of the same exercise. The base exercise fields act as variant 0; the runner picks a random variant per attempt. Translations of the exercise must define the same number of variants in the same order.",
      "properties": {
        "prompt": {
          "type": "string",
          "minLength": 5
        },
        "fixture": {
          "type": "string"
        },
        "starter": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "snippet": {
          "type": "string"
        },
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "text"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          }
        },
        "correct": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "explanation": {
          "type": "string"
        },
        "cases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "call"
            ],
            "properties": {
              "call": {
                "type": "string"
              },
              "expect": {},
              "expect_approx": {
                "type": "number"
              }
            }
          }
        },
        "blanks": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "accept_regex": {
                "type": "string"
              }
            }
          }
        },
        "expected": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "result-set",
                "scalar",
                "stdout"
              ]
            },
            "ordered": {
              "type": "boolean"
            },
            "rows": {
              "type": "array"
            },
            "value": {}
          }
        },
        "solution": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "setup": {
          "$ref": "#/$defs/gitSetup"
        },
        "goal": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/gitGoal"
          }
        }
      }
    },
    "gitSetup": {
      "type": "object",
      "description": "Initial repository state for a git-challenge before the learner runs any commands.",
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "object",
          "description": "Worktree files seeded before setup commands run, keyed by path with file contents as values.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "description": "Git/shell commands replayed by the engine to build the starting state.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "gitGoal": {
      "type": "object",
      "description": "A single assertion checked against the resulting repository state. The challenge passes when every goal holds.",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "commit-count",
            "file-content",
            "file-tracked",
            "file-absent",
            "staged",
            "branch-exists",
            "branch-absent",
            "head-on-branch",
            "head-detached",
            "head-at",
            "clean-tree",
            "merged",
            "commit-message",
            "tag-exists"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "equals": {},
        "where": {
          "type": "string",
          "enum": [
            "worktree",
            "head"
          ]
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "into": {
          "type": "string",
          "minLength": 1
        },
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "contains": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "commit-count"
              }
            }
          },
          "then": {
            "required": [
              "equals"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "file-content"
              }
            }
          },
          "then": {
            "required": [
              "path",
              "equals"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "file-tracked",
                  "file-absent",
                  "staged"
                ]
              }
            }
          },
          "then": {
            "required": [
              "path"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "branch-exists",
                  "branch-absent",
                  "head-on-branch",
                  "tag-exists"
                ]
              }
            }
          },
          "then": {
            "required": [
              "name"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "head-at"
              }
            }
          },
          "then": {
            "required": [
              "ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "merged"
              }
            }
          },
          "then": {
            "required": [
              "branch"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "commit-message"
              }
            }
          },
          "then": {
            "required": [
              "contains"
            ]
          }
        }
      ]
    }
  }
}
