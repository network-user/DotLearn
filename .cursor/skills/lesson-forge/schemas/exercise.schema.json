{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dotlearn.dev/schemas/exercise.schema.json",
  "title": "ExerciseFile",
  "type": "object",
  "additionalProperties": false,
  "required": ["exercises"],
  "properties": {
    "exercises": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/exercise" }
    }
  },
  "$defs": {
    "exercise": {
      "type": "object",
      "required": ["id", "concept", "type", "difficulty", "prompt"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "concept": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" },
        "type": {
          "type": "string",
          "enum": [
            "theory-quiz",
            "sql-query",
            "python-function",
            "javascript-function",
            "fill-in-blanks",
            "predict-output"
          ]
        },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
        "prompt": { "type": "string", "minLength": 5 },
        "hints": { "type": "array", "items": { "type": "string" } },
        "fixture": { "type": "string" },
        "starter": { "type": "string" },
        "template": { "type": "string" },
        "snippet": { "type": "string" },
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        },
        "correct": { "type": "array", "items": { "type": "string" } },
        "explanation": { "type": "string" },
        "cases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["call"],
            "properties": {
              "call": { "type": "string" },
              "expect": {},
              "expect_approx": { "type": "number" }
            }
          }
        },
        "blanks": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "accept": { "type": "array", "items": { "type": "string" } },
              "accept_regex": { "type": "string" }
            }
          }
        },
        "expected": {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "enum": ["result-set", "scalar", "stdout"] },
            "ordered": { "type": "boolean" },
            "rows": { "type": "array" },
            "value": {}
          }
        },
        "solution": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "theory-quiz" } } },
          "then": { "required": ["choices", "correct"] }
        },
        {
          "if": { "properties": { "type": { "const": "sql-query" } } },
          "then": { "required": ["fixture", "expected", "solution"] }
        },
        {
          "if": { "properties": { "type": { "enum": ["python-function", "javascript-function"] } } },
          "then": { "required": ["starter", "cases", "solution"] }
        },
        {
          "if": { "properties": { "type": { "const": "fill-in-blanks" } } },
          "then": { "required": ["template", "blanks"] }
        },
        {
          "if": { "properties": { "type": { "const": "predict-output" } } },
          "then": { "required": ["snippet", "expected"] }
        }
      ]
    }
  }
}
