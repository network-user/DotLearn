{
  "name": "dotlearn",
  "version": "0.0.1",
  "private": true,
  "description": "Local-first, AI-extensible learning workbench. Codegen-friendly topics.",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@dotlearn/web",
    "dev:api": "turbo run dev --filter=@dotlearn/api",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "validate": "turbo run validate --filter=@dotlearn/lesson-engine",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync:skills": "node scripts/sync-skills.mjs",
    "check:skills": "node scripts/sync-skills.mjs --check",
    "import:interview": "node scripts/scrape-interview.mjs",
    "build:interview-index": "node scripts/build-interview-index.mjs",
    "build:interview-flashcards": "pnpm --filter @dotlearn/lesson-engine build:interview-flashcards",
    "reorg:interview": "node scripts/reorg-interview.mjs",
    "validate:interview-exercises": "node scripts/validate-interview-exercises.mjs",
    "check:interview": "node scripts/check-interview.mjs",
    "verify:interview-py": "python scripts/verify-fix-interview.py"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "eslint": "^9.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.9.0",
    "playwright-core": "^1.60.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.5.0"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.1.1",
      "lodash": ">=4.18.1",
      "qs": ">=6.15.2"
    }
  }
}
