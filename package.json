{
  "name": "dotlearn",
  "version": "0.0.1",
  "private": true,
  "description": "Local-first, AI-extensible learning workbench. Codegen-friendly topics.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@dotlearn/web",
    "dev:api": "turbo run dev --filter=@dotlearn/api",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "validate": "turbo run validate --filter=@dotlearn/lesson-engine",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync:skills": "node scripts/sync-skills.mjs",
    "check:skills": "node scripts/sync-skills.mjs --check",
    "check:headers": "node scripts/check-csp-sync.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "import:interview": "node scripts/scrape-interview.mjs",
    "build:interview-index": "node scripts/build-interview-index.mjs",
    "build:interview-flashcards": "pnpm --filter @dotlearn/lesson-engine build:interview-flashcards",
    "reorg:interview": "node scripts/reorg-interview.mjs",
    "validate:interview-exercises": "node scripts/validate-interview-exercises.mjs",
    "check:interview": "node scripts/check-interview.mjs",
    "verify:interview-py": "python scripts/verify-fix-interview.py"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "eslint": "^9.10.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.9.0",
    "lint-staged": "^15.2.0",
    "playwright-core": "^1.61.1",
    "prettier": "^3.9.4",
    "turbo": "^2.10.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.63.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,mdx,yml,yaml,css}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.2.0",
      "lodash": ">=4.18.1",
      "qs": ">=6.15.2",
      "undici": "^7.28.0",
      "@opentelemetry/core": ">=2.8.0",
      "@nestjs/swagger>js-yaml": "^4.2.0",
      "test-exclude>glob": "10.5.0"
    }
  }
}
