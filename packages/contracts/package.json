{
  "name": "@dotlearn/contracts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/cjs/index.js",
      "default": "./src/index.ts"
    },
    "./topic": {
      "types": "./src/topic.schema.ts",
      "require": "./dist/cjs/topic.schema.js",
      "default": "./src/topic.schema.ts"
    },
    "./exercise": {
      "types": "./src/exercise.schema.ts",
      "require": "./dist/cjs/exercise.schema.js",
      "default": "./src/exercise.schema.ts"
    },
    "./submission": {
      "types": "./src/submission.schema.ts",
      "require": "./dist/cjs/submission.schema.js",
      "default": "./src/submission.schema.ts"
    },
    "./flashcard": {
      "types": "./src/flashcard.schema.ts",
      "require": "./dist/cjs/flashcard.schema.js",
      "default": "./src/flashcard.schema.ts"
    },
    "./admin-topics": {
      "types": "./src/admin-topics.schema.ts",
      "require": "./dist/cjs/admin-topics.schema.js",
      "default": "./src/admin-topics.schema.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json',JSON.stringify({type:'commonjs'}))\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
