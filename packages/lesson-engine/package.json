{
  "name": "@dotlearn/lesson-engine",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./node": "./src/node.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate": "tsx src/cli/validate-topics.ts",
    "precompute:demos": "tsx src/cli/precompute-demo-outputs.ts",
    "build:interview-flashcards": "tsx src/cli/build-interview-flashcards.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dotlearn/contracts": "workspace:*",
    "@mdx-js/mdx": "^3.0.0",
    "pyodide": "^0.26.4",
    "sql.js": "^1.10.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/sql.js": "^1.4.9",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.23.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  }
}
