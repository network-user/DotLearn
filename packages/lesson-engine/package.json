{
  "name": "@dotlearn/lesson-engine",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./node": "./src/node.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate": "tsx src/cli/validate-topics.ts",
    "precompute:demos": "tsx src/cli/precompute-demo-outputs.ts",
    "build:interview-flashcards": "tsx src/cli/build-interview-flashcards.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dotlearn/contracts": "workspace:*",
    "@mdx-js/mdx": "^3.0.0",
    "pyodide": "^314.0.3",
    "sql.js": "^1.10.0",
    "yaml": "^2.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/sql.js": "^1.4.9",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.7.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
