# Normalize text files to LF in the repo so Prettier/CI (Linux) and Windows
# checkouts do not fight over CRLF (core.autocrlf alone is not enough).
* text=auto eol=lf

# Windows shell scripts keep CRLF when needed.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
