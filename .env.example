# ------------------------------------------------------------
# DotLearn deployment config. Copy to `.env` and fill in.
# `scripts/deploy.sh` creates and completes this file for you.
# Single source of truth for both the web build and the API runtime.
# ------------------------------------------------------------

# ── Public site ─────────────────────────────────────────────
# Domain the site is served on. Drives HTTPS (Let's Encrypt) and CORS.
DOMAIN=example.com
# Contact email for the Let's Encrypt / ACME account.
ACME_EMAIL=you@example.com

# ── Frontend build-time config (baked into the static bundle) ─
# Same origin as the site: Caddy proxies the API under /api.
# Keep in sync with DOMAIN (deploy.sh sets it to https://$DOMAIN).
VITE_API_BASE=https://example.com
# Hard-to-guess admin route path, e.g. /secret-admin-7f2c.
VITE_ADMIN_PATH=/admin

# ── API runtime ─────────────────────────────────────────────
NODE_ENV=production
# Bind to loopback only; Caddy reverse-proxies to it (bare-metal).
# Docker uses 0.0.0.0 via its own default — leave 127.0.0.1 here.
HOST=127.0.0.1
PORT=3000
# CORS allowlist (comma-separated). Must equal the public origin.
WEB_ORIGIN=https://example.com
# Number of reverse proxies in front of the API (Caddy = 1).
TRUSTED_PROXY_HOPS=1
# Where the API persists submissions/hidden-topics (json-file-store).
# Bare-metal: /var/lib/dotlearn/data. Docker: /app/data.
DATA_DIR=/var/lib/dotlearn/data

# ── Admin account ───────────────────────────────────────────
# Secrets are generated by deploy.sh — leave them empty here.
#   node apps/api/scripts/gen-admin-secrets.mjs <password>
ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=
ADMIN_TOTP_SECRET=
ADMIN_BACKUP_CODES_HASHED=[]
ADMIN_JWT_SECRET=
ADMIN_REFRESH_SECRET=

# Optional auth tuning (seconds). Sensible defaults in auth.config.ts.
ADMIN_ACCESS_TTL=900
ADMIN_REFRESH_TTL=604800
ADMIN_STEPUP_TTL=120
ADMIN_LOCKOUT_TTL=300
ADMIN_LOGIN_WINDOW=900
ADMIN_MAX_FAILED_ATTEMPTS=5
# Cookie scoping for the refresh token. Leave empty for host-only
# (correct for same-origin web+api). Set `.example.com` for subdomains.
ADMIN_COOKIE_DOMAIN=

# ── Search (optional, OFF by default) ───────────────────────
# false → in-memory fuzzy search (enough for dozens of submissions;
#         zero extra RAM/disk — recommended for a small server).
# true  → requires a reachable Elasticsearch at ES_NODE.
ES_ENABLED=false
ES_NODE=http://127.0.0.1:9200
ES_USERNAME=
ES_PASSWORD=
ES_API_KEY=
ES_SUBMISSIONS_INDEX=dotlearn-submissions

# ── Docker-only (ignored by the bare-metal deploy) ──────────
WEB_PORT=8080
API_PORT=3000
ES_PORT=9200
