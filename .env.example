# ------------------------------------------------------------
# DotLearn deployment environment.
# Copy this file to `.env` (root), fill in secrets, then run
# `docker compose up --build -d`.
# ------------------------------------------------------------

# Ports exposed by docker-compose on the host.
WEB_PORT=8080
API_PORT=3000
ES_PORT=9200

# Where the frontend will reach the API. In a typical deploy
# this is the public URL of the API service (or, behind a
# reverse proxy, a same-origin path like https://example.com).
VITE_API_BASE=http://localhost:3000

# Admin path on the frontend. Make this hard to guess.
# Default `/admin` is fine for local dev.
VITE_ADMIN_PATH=/admin

# Origins allowed to call the API (comma-separated). Must match
# the public origin of the web container.
WEB_ORIGIN=http://localhost:8080

# ------------------------------------------------------------
# Admin authentication.
# Generate with:
#   pnpm --filter @dotlearn/api admin:hash <password>
#   pnpm --filter @dotlearn/api admin:totp
#   pnpm --filter @dotlearn/api admin:jwt-secret
# ------------------------------------------------------------
ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=
ADMIN_TOTP_SECRET=
ADMIN_BACKUP_CODES_HASHED=[]
ADMIN_JWT_SECRET=
ADMIN_REFRESH_SECRET=

# Optional auth tuning (seconds).
ADMIN_ACCESS_TTL=900
ADMIN_REFRESH_TTL=604800
ADMIN_STEPUP_TTL=120
ADMIN_LOCKOUT_TTL=300
ADMIN_LOGIN_WINDOW=900
ADMIN_MAX_FAILED_ATTEMPTS=5

# Cookie scoping for the refresh token. Leave empty for default.
# Set to a domain like `.example.com` when serving web+api on
# different subdomains.
ADMIN_COOKIE_DOMAIN=

# ------------------------------------------------------------
# Search.
# Set ES_ENABLED=true to back the search service with the
# elasticsearch container. Leave blank/false to use the
# in-memory fuzzy implementation (fine for small datasets).
# ------------------------------------------------------------
ES_ENABLED=true
ES_NODE=http://elasticsearch:9200
ES_USERNAME=
ES_PASSWORD=
ES_API_KEY=
ES_SUBMISSIONS_INDEX=dotlearn-submissions

# ------------------------------------------------------------
# Data directory mounted into the api container.
# Override with caution — submissions and hidden-topics files
# live here.
# ------------------------------------------------------------
DATA_DIR=/app/data
