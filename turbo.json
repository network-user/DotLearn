{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../../topics/**"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "validate": {
      "inputs": ["$TURBO_DEFAULT$", "../../topics/**"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$"]
    }
  }
}
