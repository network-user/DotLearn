{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "../../topics/**"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV", "VITE_API_BASE", "VITE_ADMIN_PATH", "VITE_GITHUB_URL", "VITE_SITE_URL"]
    },
    "typecheck": {
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "validate": {
      "inputs": ["$TURBO_DEFAULT$", "../../topics/**"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$"]
    }
  }
}
