{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dotlearn.dev/schemas/manifest.schema.json",
  "title": "TopicManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "version",
    "availableLanguages",
    "primaryLanguage",
    "difficulty",
    "estimatedHours",
    "runtime",
    "prerequisites",
    "tags",
    "author",
    "concepts",
    "license"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
      "minLength": 3,
      "maxLength": 60
    },
    "title": { "type": "string", "minLength": 3, "maxLength": 80 },
    "titleEn": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "description": "English title for /en/* pages. Required when \"en\" is listed in availableLanguages (regardless of primaryLanguage); must be omitted otherwise."
    },
    "descriptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ru": { "type": "string", "minLength": 50, "maxLength": 200 },
        "en": { "type": "string", "minLength": 50, "maxLength": 200 }
      },
      "description": "SEO descriptions of the topic per language (meta description). The primaryLanguage key is always required. The en key is required when \"en\" is listed in availableLanguages. Only keys listed in availableLanguages are allowed."
    },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "availableLanguages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["en", "ru"] }
    },
    "primaryLanguage": { "type": "string", "enum": ["en", "ru"] },
    "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
    "estimatedHours": { "type": "number", "minimum": 0.25, "maximum": 200 },
    "runtime": { "type": "string", "enum": ["sql.js", "pyodide", "javascript", "git", "none"] },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" },
      "uniqueItems": true
    },
    "relatedTopics": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" },
      "uniqueItems": true,
      "description": "Optional non-blocking cross-links to sibling topics, distinct from hard prerequisites."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": { "type": "string", "enum": ["agent", "human"] },
        "name": { "type": "string" },
        "model": { "type": "string" }
      }
    },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "estimatedMinutes", "theoryFiles", "exerciseFiles"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" },
          "title": { "type": "string", "minLength": 3 },
          "estimatedMinutes": { "type": "integer", "minimum": 5, "maximum": 240 },
          "theoryFiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^theory/\\d{2}-[a-z0-9-]+\\.(en|ru)\\.mdx$"
            }
          },
          "exerciseFiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^exercises/\\d{2}-[a-z0-9-]+\\.(en|ru)\\.yaml$"
            }
          }
        }
      }
    },
    "license": {
      "type": "string",
      "enum": ["MIT", "Apache-2.0", "CC-BY-4.0", "CC-BY-SA-4.0", "CC-BY-NC-4.0"]
    },
    "sources": {
      "type": "array",
      "description": "Optional attribution: external references the topic draws on.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
