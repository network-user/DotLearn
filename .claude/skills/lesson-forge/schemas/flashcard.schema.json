{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dotlearn.dev/schemas/flashcard.schema.json",
  "title": "FlashcardDeck",
  "type": "object",
  "additionalProperties": false,
  "required": ["conceptId", "cards"],
  "properties": {
    "conceptId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" },
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "front", "back"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "front": { "type": "string", "minLength": 3 },
          "back": { "type": "string", "minLength": 3 },
          "tags": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
          }
        }
      }
    }
  }
}
