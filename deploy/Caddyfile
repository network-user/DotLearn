# DotLearn — Caddy site config.
# Installed to /etc/caddy/Caddyfile by scripts/deploy.sh, which feeds
# DOMAIN / ACME_EMAIL / WEB_ROOT / API_UPSTREAM via a systemd drop-in.
# Caddy serves the static SPA, reverse-proxies /api to the local NestJS
# process, and obtains/renews a Let's Encrypt certificate automatically.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	# Security headers. The Content-Security-Policy is served as a real response
	# header here: frame-ancestors (and HSTS) are ignored when CSP ships only via
	# <meta>. connect-src is 'self' because the SPA and API are same-origin behind
	# this proxy. Keep the policy in sync with apps/web/security-headers.conf.
	header {
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; manifest-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; worker-src 'self' blob:; child-src 'self' blob:; connect-src 'self'"
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), usb=(), payment=()"
		Cross-Origin-Opener-Policy "same-origin"
		-Server
	}

	# API → local NestJS process (loopback).
	handle /api/* {
		reverse_proxy {$API_UPSTREAM:127.0.0.1:3000} {
			header_up X-Forwarded-For {remote_host}
		}
	}

	# Static single-page app with history-API fallback.
	handle {
		root * {$WEB_ROOT}

		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# Navigational HTML (the SPA shell + every prerendered mirror) must always be
		# revalidated so a new deploy's asset hashes/content show up immediately.
		@navHtml path / /index.html /topics/* /en/* /404.html /flashcards* /glossary* /interview* /tracks* /map* /sandbox*
		header @navHtml Cache-Control "no-store"

		# .md mirrors live under /topics/*.md and /en/topics/*.md, so they also match
		# @navHtml above; declaring this matcher afterwards makes its Cache-Control
		# win (Caddy's `header` sets/overwrites, and same-named directives keep their
		# Caddyfile order), giving documents a real cache lifetime instead of no-store.
		@docsCache path *.md /llms.txt /llms-full.txt /sitemap.xml /robots.txt
		header @docsCache Cache-Control "public, max-age=3600"

		@markdown path *.md
		header @markdown Content-Type "text/markdown; charset=utf-8"

		try_files {path} {path}/index.html /index.html
		file_server
	}
}
